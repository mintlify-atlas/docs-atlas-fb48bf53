  "keyFeatures": [
    "Product catalog with search, category filtering, and price range filters",
    "Role-based authentication (user, emprendedor, administrador)",
    "Entrepreneur dashboard to create, edit, and delete products",
    "Admin dashboard with platform statistics and PDF report generation",
    "Favorites system for registered users",
    "Password recovery and reset flow",
    "Entrepreneur directory listing",
    "Splash screen and skeleton loading states for improved UX",
    "JWT-based session management with automatic logout on expiry"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
    "POST /api/auth/register",
    "GET /api/products",
    "GET /api/products/:id",
    "GET /api/entrepreneurs/mis-productos",
    "POST /api/entrepreneurs (create product)",
    "PUT /api/entrepreneurs/:id (update product)",
    "DELETE /api/entrepreneurs/:id",
    "GET /api/admin/stats",
    "GET /api/admin/usuarios",
    "GET /api/admin/productos"
  ]
